    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.4.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
